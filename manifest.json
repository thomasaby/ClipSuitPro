{
  "manifest_version": 3,
  "name": "ClipSuit",
  "version": "1.0.0",
  "description": "Capture, save, and browse code snippets locally.",
  "permissions": ["storage", "clipboardRead", "unlimitedStorage", "contextMenus"],
  "action": {
    "default_title": "ClipSuit",
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  }
}